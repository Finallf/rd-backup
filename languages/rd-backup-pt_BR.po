#. Plugin URI of the plugin
#: rd-backup.php
msgid "https://github.com/Finallf/rd-backup"
msgstr "https://github.com/Finallf/rd-backup"

#. Description of the plugin
#: rd-backup.php
msgid ""
"Complete, portable WordPress backup & restore — a full database dump plus "
"the uploads folder in a single .zip, restorable on any host. Pairs with the "
"ReloadeD theme but runs standalone with any theme."
msgstr ""
"Backup e restauração completos e portáteis para WordPress — um dump completo "
"do banco de dados mais a pasta de uploads em um único .zip, restaurável em "
"qualquer host. Combina com o tema ReloadeD, mas funciona de forma "
"independente com qualquer tema."

#. Author of the plugin
#: rd-backup.php
msgid "Regis Vieira Delgado"
msgstr "Regis Vieira Delgado"

